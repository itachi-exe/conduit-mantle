# Copy to .env.local and fill in real values. Nothing here is optional for
# the agent layer; the data layer (RPC + DefiLlama) works with zero setup.

# Real DeepSeek API key (https://platform.deepseek.com/api_keys).
# Powers /api/brief — the ecosystem/signal/asset summaries. High-frequency,
# no tool use needed, so it runs on DeepSeek (deepseek-v4-flash) rather than
# Claude: ~20x cheaper per call for the same "turn these real numbers into a
# sentence" job. Without it, /api/brief returns an honest 503 and the UI
# shows "Agent call failed" instead of fake text.
DEEPSEEK_API_KEY=

# Real Anthropic API key (https://console.anthropic.com/settings/keys).
# Powers /api/chat — the research chat. This one needs Claude specifically:
# real tool-calling (get_protocol_detail, search_mantle_protocols, etc.) and
# Anthropic's hosted web_search tool, which DeepSeek doesn't have. Same
# honest-503 behavior if missing.
ANTHROPIC_API_KEY=

# Optional: override the public Mantle RPC endpoint (defaults to
# https://rpc.mantle.xyz, no key required).
MANTLE_RPC_URL=
